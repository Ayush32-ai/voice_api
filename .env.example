DATABASE_URL=postgresql+asyncpg://user:password@localhost/dubbing_studio
REDIS_URL=redis://localhost:6379
SECRET_KEY=ai-dubbing-studio-secret-key-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Service API Keys - only GROQ needed for free tier speech-to-text
# Get free key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional paid/premium providers (not required)
OPENAI_API_KEY=your-openai-key-here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
GEMINI_API_KEY=your-gemini-key-here

# Free provider defaults (no payment)
TTS_PROVIDER=gtts
TRANSLATION_PROVIDER=google
STT_PROVIDER=groq

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE=104857600  # 100MB

# Processing Settings
CHUNK_SIZE=8192
MAX_WORKERS=4
TEMP_DIR=temp

# Set true ONLY if you run a separate Celery worker service
USE_CELERY_WORKER=false