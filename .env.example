DATABASE_URL=postgresql+asyncpg://user:password@localhost/dubbing_studio
REDIS_URL=redis://localhost:6379
SECRET_KEY=ai-dubbing-studio-secret-key-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Service API Keys - ALL OPTIONAL (free providers work without any keys)
# Optional: better speech-to-text quality with free GROQ tier
# Get free key at: https://console.groq.com/
GROQ_API_KEY=

# Optional paid/premium providers
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
GEMINI_API_KEY=

# Free provider defaults (zero API keys required)
TTS_PROVIDER=gtts
TRANSLATION_PROVIDER=google
STT_PROVIDER=google

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE=104857600  # 100MB

# Processing Settings
CHUNK_SIZE=8192
MAX_WORKERS=4
TEMP_DIR=temp

# Set true ONLY if you run a separate Celery worker service
USE_CELERY_WORKER=false